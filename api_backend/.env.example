# PostgreSQL connection string for SQLAlchemy async engine.
# Preferred: postgresql+asyncpg://...
# Compatibility: postgresql://... will be auto-converted to postgresql+asyncpg://...
#
# Provided by postgres_db container in this environment (via POSTGRES_URL).
# Some environments may instead provide DATABASE_URL (supported as an alias).
POSTGRES_URL=postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DB
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB

# Optional cache TTL for compare results (seconds)
CACHE_TTL_SECONDS=900
